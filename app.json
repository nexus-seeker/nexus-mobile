{
  "expo": {
    "name": "Kawula",
    "slug": "kawula-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.benelabs.kawula"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.benelabs.kawula"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ],
    "fonts": {
      "Geist-Regular": "./assets/fonts/Geist-Regular.otf",
      "Geist-Medium": "./assets/fonts/Geist-Medium.otf",
      "Geist-SemiBold": "./assets/fonts/Geist-SemiBold.otf",
      "Geist-Bold": "./assets/fonts/Geist-Bold.otf",
      "GeistMono-Regular": "./assets/fonts/GeistMono-Regular.otf"
    }
  }
}